h1, h2, h3 { line-height: 1.25; }

/* Responsive */
@media (max-width: 768px) {
  .navbar { padding: 14px 18px; flex-wrap: wrap; gap: 10px; }
  .navbar-links { gap: 14px; font-size: 13px; }
  .hero h1 { font-size: 30px; }
  .hero p { font-size: 14px; }
  .detail-layout { flex-direction: column; }
  .detail-image { width: 100%; height: 300px; }
  .product-grid { grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 14px; }
  .chat-window { width: 90vw; right: 5vw; }
}
/* Hero premium */
.hero-premium {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 40px;
  background: linear-gradient(135deg, #1a1a2e 0%, #2b2d42 50%, #ff6b35 150%);
  flex-wrap: wrap;
}
.hero-content { text-align: left; max-width: 480px; }
.hero-content p { margin-left: 0; }
.hero-cta-group { display: flex; gap: 14px; }
.hero-outline { background: transparent; color: white; border-color: rgba(255,255,255,.4) !important; }
.hero-outline:hover { background: rgba(255,255,255,.1); }
.hero-images { position: relative; width: 320px; height: 260px; flex-shrink: 0; }
.hero-float { position: absolute; width: 130px; height: 130px; object-fit: cover; border-radius: 16px; box-shadow: 0 12px 30px rgba(0,0,0,.35); animation: heroFloat 4s ease-in-out infinite; }
.hero-float-1 { top: 0; left: 0; animation-delay: 0s; }
.hero-float-2 { top: 10px; right: 0; animation-delay: .5s; }
.hero-float-3 { bottom: 0; left: 40px; animation-delay: 1s; }
.hero-float-4 { bottom: 10px; right: 30px; animation-delay: 1.5s; }
@keyframes heroFloat { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-12px); } }
@media (max-width: 900px) { .hero-premium { flex-direction: column; text-align: center; } .hero-content { text-align: center; } .hero-cta-group { justify-content: center; } .hero-images { display: none; } }

/* Product card extras */
.product-card-stars { font-size: 11px; margin: 0 0 6px; }
.product-card-stars span { color: var(--text-muted); font-size: 11px; }
.product-card-price { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
.strike-price { font-size: 12px; color: var(--text-muted); text-decoration: line-through; font-weight: 400; }
.discount-badge { background: #e6faf4; color: var(--success); font-size: 10px; font-weight: 700; padding: 2px 8px; border-radius: 10px; }
.free-delivery { font-size: 11px; color: var(--text-muted); margin: 4px 0 0; }

/* Button gradient/hover polish */
.btn-outline:hover { transform: translateY(-1px); }
